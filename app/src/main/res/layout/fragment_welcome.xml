<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F0F4F8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kulaan.id"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#1A3C5E"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marketplace UMKM Lokal"
        android:textSize="15sp"
        android:textColor="#6C757D"
        android:layout_marginBottom="60dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saya adalah..."
        android:textSize="18sp"
        android:textColor="#343A40"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_buyer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🛒  Pembeli"
        android:textSize="16sp"
        app:backgroundTint="#1A3C5E"
        app:cornerRadius="14dp"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_seller"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🏪  Penjual / UMKM"
        android:textSize="16sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#1A3C5E"
        app:strokeWidth="2dp"
        android:textColor="#1A3C5E"
        app:cornerRadius="14dp"/>

</LinearLayout>
